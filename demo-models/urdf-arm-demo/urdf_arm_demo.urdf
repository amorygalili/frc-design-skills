<?xml version="1.0"?>
<!-- cadpy:sourcePath=urdf_arm_demo.py -->
<!-- cadpy:sourceHash=b62e8bd8d34cc7c13619a3853e2ef6c2df1deece014a2848a9c7aba8f814ccc6 -->
<robot name="urdf_arm_demo">
  <link name="base_footprint" />
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.3 0.3 0.08" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.3 0.3 0.08" />
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="4" />
      <inertia ixx="0.0321333" ixy="0" ixz="0" iyy="0.0321333" iyz="0" izz="0.06" />
    </inertial>
  </link>
  <joint name="base_footprint_to_base" type="fixed">
    <parent link="base_footprint" />
    <child link="base_link" />
    <origin xyz="0 0 0.04" rpy="0 0 0" />
  </joint>
  <link name="shoulder_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.06" length="0.12" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.06" length="0.12" />
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="1.5" />
      <inertia ixx="0.00315" ixy="0" ixz="0" iyy="0.00315" iyz="0" izz="0.0027" />
    </inertial>
  </link>
  <joint name="shoulder_pan_joint" type="revolute">
    <parent link="base_link" />
    <child link="shoulder_link" />
    <origin xyz="0 0 0.1" rpy="0 0 0" />
    <axis xyz="0 0 1" />
    <limit lower="-2.96706" upper="2.96706" effort="40" velocity="2" />
  </joint>
  <link name="upper_arm_link">
    <visual>
      <origin xyz="0.14 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.28 0.06 0.06" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0.14 0 0" rpy="0 1.5708 0" />
      <geometry>
        <cylinder radius="0.025" length="0.28" />
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.14 0 0" rpy="0 0 0" />
      <mass value="1.2" />
      <inertia ixx="0.00072" ixy="0" ixz="0" iyy="0.0082" iyz="0" izz="0.0082" />
    </inertial>
  </link>
  <joint name="shoulder_lift_joint" type="revolute">
    <parent link="shoulder_link" />
    <child link="upper_arm_link" />
    <origin xyz="0 0 0.06" rpy="0 0 0" />
    <axis xyz="0 1 0" />
    <limit lower="-0.785398" upper="1.5708" effort="40" velocity="2" />
  </joint>
  <link name="forearm_link">
    <visual>
      <origin xyz="0.1 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.2 0.05 0.05" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0.1 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.2 0.05 0.05" />
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.1 0 0" rpy="0 0 0" />
      <mass value="0.8" />
      <inertia ixx="0.000333333" ixy="0" ixz="0" iyy="0.00283333" iyz="0" izz="0.00283333" />
    </inertial>
  </link>
  <joint name="forearm_extend_joint" type="prismatic">
    <parent link="upper_arm_link" />
    <child link="forearm_link" />
    <origin xyz="0.28 0 0" rpy="0 0 0" />
    <axis xyz="1 0 0" />
    <limit lower="0" upper="0.15" effort="100" velocity="0.1" />
  </joint>
  <link name="wrist_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <sphere radius="0.04" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <sphere radius="0.04" />
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.3" />
      <inertia ixx="0.000192" ixy="0" ixz="0" iyy="0.000192" iyz="0" izz="0.000192" />
    </inertial>
  </link>
  <joint name="wrist_roll_joint" type="continuous">
    <parent link="forearm_link" />
    <child link="wrist_link" />
    <origin xyz="0.2 0 0" rpy="0 0 0" />
    <axis xyz="1 0 0" />
    <limit effort="10" velocity="3" />
  </joint>
  <link name="tool0" />
  <joint name="wrist_to_tool0" type="fixed">
    <parent link="wrist_link" />
    <child link="tool0" />
    <origin xyz="0.04 0 0" rpy="0 0 0" />
  </joint>
</robot>
